# Clerk (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# Convex (required)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment

# AI – Suggestion API (optional, for inline suggestions)
OPENAI_API_KEY=sk-...

# AI – Quick Edit & Inngest (optional)
GOOGLE_GENERATIVE_AI_API_KEY=...

# Firecrawl – URL scraping in Quick Edit & Inngest (optional)
FIRECRAWL_API_KEY=...

# Sentry (optional)
# SENTRY_AUTH_TOKEN=...
# See Sentry Next.js docs for other SENTRY_* vars
